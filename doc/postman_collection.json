    {
      "name": "Consola Cypher",
      "item": [
        {
          "name": "POST /cypher — read",
          "request": {
            "method": "POST",
            "url": "{{base}}/cypher",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"MATCH (u:Usuario) RETURN u.nombre AS nombre, u.conexiones_count AS conexiones ORDER BY conexiones DESC LIMIT 5\",\n  \"params\": {},\n  \"mode\": \"read\"\n}"
            }
          }
        },
        {
          "name": "POST /cypher — write",
          "request": {
            "method": "POST",
            "url": "{{base}}/cypher",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"MATCH (u:Usuario {userId: $id}) SET u.activo = true RETURN u\",\n  \"params\": { \"id\": \"n1\" },\n  \"mode\": \"write\"\n}"
            }
          }
        },
