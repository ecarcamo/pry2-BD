          "request": { "method": "GET", "url": "{{base}}/usuarios/" }
        },
        {
          "name": "GET /usuarios/ — con filtros (consulta agregada)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base}}/usuarios/?abierto_a_trabajo=true&limit=10&orderBy=conexiones_count&dir=DESC",
              "host": ["{{base}}"],
              "path": ["usuarios", ""],
              "query": [
                { "key": "abierto_a_trabajo", "value": "true" },
                { "key": "limit", "value": "10" },
                { "key": "orderBy", "value": "conexiones_count" },
                { "key": "dir", "value": "DESC" }
              ]
            }
          }
        },
        {
          "name": "GET /usuarios/:usuario_id/ — detalle",
          "request": { "method": "GET", "url": "{{base}}/usuarios/u0/" }
        },
        {
          "name": "PATCH /usuarios/:usuario_id/ — agregar/actualizar/quitar props (1 nodo)",
          "request": {
            "method": "PATCH",
            "url": "{{base}}/usuarios/u0/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"set\": {\n    \"telefono\": \"+502 5555-1234\",\n    \"pais\": \"Guatemala\"\n  },\n  \"remove\": []\n}"
            }
          }
        },
        {
          "name": "PATCH /usuarios/:usuario_id/ — eliminar props (1 nodo)",
          "request": {
            "method": "PATCH",
            "url": "{{base}}/usuarios/u0/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"set\": {},\n  \"remove\": [\"telefono\", \"pais\"]\n}"
            }
          }
        },
        {
          "name": "POST /usuarios/bulk-update/ — patch masivo (varios nodos)",
          "request": {
            "method": "POST",
            "url": "{{base}}/usuarios/bulk-update/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"filter\": { \"abierto_a_trabajo\": true },\n  \"set\": { \"disponible_inmediatamente\": true },\n  \"remove\": []\n}"
            }
          }
        },
        {
          "name": "POST /usuarios/bulk-update/ — eliminar prop a varios",
          "request": {
            "method": "POST",
            "url": "{{base}}/usuarios/bulk-update/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"filter\": { \"abierto_a_trabajo\": true },\n  \"set\": {},\n  \"remove\": [\"disponible_inmediatamente\"]\n}"
            }
          }
        },
        {
          "name": "DELETE /usuarios/:usuario_id/ — eliminar 1 nodo",
          "request": { "method": "DELETE", "url": "{{base}}/usuarios/u-test-id/" }
        }
      ]
    },

