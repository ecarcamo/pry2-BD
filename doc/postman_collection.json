              "raw": "{\n  \"query\": \"MATCH (u:Usuario) RETURN u.nombre AS nombre, u.conexiones_count AS conexiones ORDER BY conexiones DESC LIMIT 5\",\n  \"params\": {},\n  \"mode\": \"read\"\n}"
            }
          }
        },
