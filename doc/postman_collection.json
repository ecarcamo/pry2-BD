{
  "info": {
    "name": "NeoLab · API Neo4j (Django + DRF)",
    "description": "Colección completa de endpoints del backend NeoLab (Django + DRF + neo4j-python-driver + Neo4j Aura). Todas las rutas viven bajo /api/ y usan slash final. Convención de IDs: snake_case (`usuario_id`, `empresa_id`, `publicacion_id`, `empleo_id`, `educacion_id`, `experiencia_id`). Los endpoints también aceptan los nombres camelCase legacy.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base", "value": "http://localhost:4000/api", "type": "string" }
  ],
  "item": [

    {
      "name": "Salud y Admin",
      "item": [
        {
          "name": "GET /ping/",
          "request": { "method": "GET", "url": "{{base}}/ping/" }
        },
        {
          "name": "POST /admin/seed/ — recargar seed",
          "request": {
            "method": "POST",
            "url": "{{base}}/admin/seed/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" }
          }
        },
        {
          "name": "GET /grafo/sample/ — sample para visualizar",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base}}/grafo/sample/?limit=150",
              "host": ["{{base}}"],
              "path": ["grafo", "sample", ""],
              "query": [{ "key": "limit", "value": "150" }]
            }
          }
        }
      ]
    },

